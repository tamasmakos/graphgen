	<!-- ### Ontologies ### -->

	<owl:Ontology rdf:about="http://publications.europa.eu/ontology/cdm/indexation">
      <owl:versionInfo>4.13.2</owl:versionInfo>
   </owl:Ontology>

	  <!-- ### Annotation properties ### -->

	<owl:AnnotationProperty rdf:about="http://publications.europa.eu/ontology/annotation#all_numbered_levels">
      <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indexation: include all levels of hierarchical properties into XML notice</rdfs:label>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicates if this field must be treated as a classification that is the basis for a facet Rules: - Directories of case law: it is a tree. We need the 4 levels, where the tag name should contain the level (e.g., _1) - Directories of legislation in force: it is a tree. We need the 4 levels, where the tag name should contain the level (e.g., _1)</rdfs:comment>
   </owl:AnnotationProperty>
   <owl:AnnotationProperty rdf:about="http://publications.europa.eu/ontology/annotation#expand_on_indexing">
      <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indexation: index notice of the domain must be expanded by an embedded index notice of the resource specified as range (applies to object properties)</rdfs:label>
   </owl:AnnotationProperty>
   <owl:AnnotationProperty rdf:about="http://publications.europa.eu/ontology/annotation#in_embedded_notice">
      <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indexation: property has to be contained within a notice fragment embedded into another objects notice.</rdfs:label>
   </owl:AnnotationProperty>
   <owl:AnnotationProperty rdf:about="http://publications.europa.eu/ontology/annotation#in_notice">
      <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indexation: property has to be present in branch, tree and object XML notices of the domain object itself.</rdfs:label>
   </owl:AnnotationProperty>
   <owl:AnnotationProperty rdf:about="http://publications.europa.eu/ontology/annotation#is_facet">
      <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indexation: Eurovoc specific handling of facets</rdfs:label>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Specific treatment for Eurovoc Rules: - Eurovoc: we need the 3 parents: Domain (_DOM), Micro Thesaurus (_MTH), and Top term (_TT). Actually, there is no problem with the current metadata format (the one available on the current EUR-Lex), because it already adds the suffix _level (_DOM/_MTH/_TT)</rdfs:comment>
   </owl:AnnotationProperty>
   <owl:AnnotationProperty rdf:about="http://publications.europa.eu/ontology/annotation#to_be_indexed">
      <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indexation: property has to be present in the index XML notice for IDOL</rdfs:label>
   </owl:AnnotationProperty>
   <owl:AnnotationProperty rdf:about="http://publications.europa.eu/ontology/annotation#write-once">
      <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Write a certain property at maximum once, afterwards block possible updates</rdfs:label>
      <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Updating a write-once property with the same value as already set is allowed; updating with a different value will raise an error on validation.</rdfs:comment>
   </owl:AnnotationProperty>

