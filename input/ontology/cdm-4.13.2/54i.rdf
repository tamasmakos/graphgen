<rdf:Description rdf:about="http://data.europa.eu/54i#Motivation">
	<rdfs:comment xml:lang="en">Strictly speaking Motivation can refer only to Actors. However, the intention is to use it in a broader sense so that the question "Why" can be put not only on the behaviours of Actors but also on e.g. Services they provide. This way a certain Public Service  can be related to Values and Objectives.</rdfs:comment>
	<rdfs:isDefinedBy rdf:resource="http://data.europa.eu/54i#"/>
	<rdfs:label xml:lang="en">Motivation</rdfs:label>
</rdf:Description>

