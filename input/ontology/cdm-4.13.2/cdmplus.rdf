		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The document remains visible even if archived</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateCreation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of creation of work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of creation in the CELLAR. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateCreationLegacy">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateCreationLegacy</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Procat and Pegase legacy creation dates</rdfs:comment>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateCreationLegacy">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legacy date of creation for dossier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legacy date of creation. if possible, original creation date of the Pegase notice. Procat and Pegase legacy creation dates. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDeadline">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateDeadline</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDeadline">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of deadline</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date for an intermediate deadline for this document. DLCOMMENT is mixed content, decoded with fd_335. DL. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDebate">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of debate</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of debate, e.g. in the European Parliament on the proposed secondary legislation. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PreparatoryAct"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDebate">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateDebate</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DB</rdfs:comment>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDeletion">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateDeletion</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDeletion">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Deletion date</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDispatch">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateDispatch</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDispatch">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dispatch date</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDispatch">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of dispatch</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of dispatch: contains the date of transmission of: Commission proposals to the Council; European Parliament resolutions to parties concerned; Economic and Social Committee. DHCOMMENT is mixed content, coded with fd_340. Date of delivery / DHDATE. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDocument">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateDocument</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateDocument">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of document</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. The date of document (possibly including annotation properties). Relevant for legal analysis: true. DD (comment as annotation). DDCOMMENT is mixed content, decoded with fd_365. DD (comment as annotation). Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateEnd">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dataset end date</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property refers to the end of the period the dataset covers</rdfs:comment>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateEndOfValidity">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateEndOfValidity</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateEndOfValidity">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of end of validity</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of the end of validity of a legal resource. Several end of validity dates are possible, e.g. partial ends of validity - EVCOMMENT is mixed content, decoded with fd_330. EV (type as annotation). Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateEntryIntoForce">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateEntryIntoForce</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateEntryIntoForce">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of entry into force</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of the entry into force of a legal resource IFCOMMENT and IFTYPE are mixed content, decoded with fd_335. IF (type as annotation). Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateExpiration">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expiration date and time</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date and time this signature loses its validity. Can be updated in case of renewal</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#DigitalSignature"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateModified">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Distribution date modified</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property contains the most recent data on which the distribution was changed or modified</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateModified">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dataset date modified</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property contains the most recent data on which the dataset was changed or modified</rdfs:comment>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateNotification">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateNotification</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NF</rdfs:comment>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateNotification">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of notification of the secondary legislation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Secondary legislation is at a given date addressed to an organization through a notification. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SecondaryLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateNotification">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of notification for a NIM</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NIMs is at a given date addressed to an organization through a notification, given by the SecGen of the Commission</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateOfficialJournal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of the national or regional Official Journal</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of the national or regional official journal on which this NIM was published</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateProcessing">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateProcessing</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateProcessing">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Processing date</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of processing (Record identifier)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionPublicationGeneral"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#datePublication">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Publication date of manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The date of publication/distribution of the manifestation. This date can be a full date in ISO format, a year only or a year and a month.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#datePublication">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Publication date of general publication</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The date that this resource was released to the public</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#GeneralPublication"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateReferral">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of referral</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of referral</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateRequestCaducity">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateRequestCaducity</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateRequestCaducity">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of request for caducity</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date at which a request for caducity was launched</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateRequestOpinion">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateRequestOpinion</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateRequestOpinion">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of request for an opinion</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of opinion request from ESC or CoR or date of deposit to the "greffe" LOCOMMENT is mixed content, coded with fd_305. Date lodged / LODATE. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateSeply">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateSeply</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">RP</rdfs:comment>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateSeply">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of reply</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of the reply to the question. RPCOMMENT and RPTYPE are mixed content, decoded with fd_350. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ParliamentaryQuestion"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateSignature">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateSignature</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateSignature">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of signature</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of signature of a legal resource. SGCOMMENT is mixed content, decoded with fd_325.SG. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateSignatureXadesA">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">XAdESA date and time</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date and time this signature got its XAdESA</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#DigitalSignature"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateSignatureXadesT">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">XAdEST date and time</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date and time this signature got its XAdEST</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#DigitalSignature"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateStart">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dataset start date</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property refers to the beginning of the period the dataset covers</rdfs:comment>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateStartHandling">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date at which work on this legal resource has actively started</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Start of processing of this legal resource. it corresponds to corext:dateActivation, at this stage only relevant for internal handling for EESC, but could also be considered for external handling. If needed, the distinction could be made via an annotation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateTransposition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition in police and judicial cooperation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition applicable to police and judicial cooperation in criminal matters; can contain multiple values as different parts of a dirctive can be implemented by various pieces of national legislation, coming with different dates (TPDATE). TPCOMMENT is mixed content, coded with fd_361. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CooperationPoliceAndJudicial"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateTransposition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateTransposition</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TP</rdfs:comment>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateTransposition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition of a decision</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition applicable to decisions; can contain multiple values as different parts of a dirctive can be implemented by various pieces of national legislation, coming with different dates (TPDATE). TPCOMMENT is mixed content, coded with fd_361. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Decision"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateTransposition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition of a directive</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Deadline for the transposition applicable to directives; can contain multiple values as different parts of a dirctive can be implemented by various pieces of national legislation, coming with different dates (TPDATE). TPCOMMENT is mixed content, coded with fd_361. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Directive"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateTransposition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition of a recommendation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition applicable to recommendation; can contain multiple values as different parts of a dirctive can be implemented by various pieces of national legislation, coming with different dates (TPDATE). TPCOMMENT is mixed content, coded with fd_361. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Recommendation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateTransposition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition of a ECSC recommendation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition applicable to recommendation of the European Coal and Steel community; can contain multiple values as different parts of a dirctive can be implemented by various pieces of national legislation, coming with different dates (TPDATE). TPCOMMENT is mixed content, coded with fd_361. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#RecommendationEcsc"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateTransposition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition of a regulation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of transposition applicable to regulations; can contain multiple values as different parts of a dirctive can be implemented by various pieces of national legislation, coming with different dates (TPDATE). TPCOMMENT is mixed content, coded with fd_361. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Regulation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateVote">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dateVote</rdfs:label>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateVote">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of vote</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of vote: contains the date of vote on resolutions of the European Parliament or ESC/CoR opinions. The date of vote is identical to the date of adoption. VO. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dateWithdrawn">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier was withdrawn on a given date</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#datetimeRequest">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Request date</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#datetimeSubmission">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Submission date</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#datetimeTransmission">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Datetime Transmission</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date on which a work was transmitted</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#decisionInternalIdentifier">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal identifier from the Court for the national decisions. limited to sector 8</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#declarationTranspositionMemberState">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transposition declaration by the Member State</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Declaration of the Member State on the state of the transposition. Possible values AU, IN, PA, NN</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#demedReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This element is used to mark up the Demed number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Demande d'editon. Added in the context of IMMC2CDM-OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#descriptionEditorial">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Documentation description</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Documentation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#descriptionEditorial">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Editorial description</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">editorial content that further elaborates the abstract with other editorial content</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#string_or_xml"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#descriptionEditorial">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Distribution description</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Distribution description</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#descriptionEditorial">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dataset description</rdfs:label>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#dimension">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dimension of manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dimension of this manifestation. mapped from 300 $c</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#directiveName">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Directive name</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#directiveNumber">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Directive number</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#doNotIndex">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">do not index</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do not index any object marked with this property, if the value is true. By default, treat the value as false</rdfs:comment>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#documentLink">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Document link</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to an external document / work e.g. in the Council or Parliament register that does not also exist in EURLex. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#documentReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Document reference</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Textual reference for a document / work that we do not know anything else about. Technical criteria is absence of any expression that we could establish. Document reference. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#doi">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOI of item</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOI of this item</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Item"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#doi">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOI of manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DOI of this manifestation. mapped from 024 7 $a</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#domain">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Domain of the court case</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This case is about a given domain, e.g. Energie or Agriculture, expressed as a string</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#draftToBePublished">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure needs draft to be published?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do the betterRegulationRequirements require that the draft be published for this internal procedure? /ns4:ecTransmissionRequest/transmission/workflow/extension/ns3:betterRegulationRequirements/ns3:draftToBePublished</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#draftToBePublished"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#durability">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Durability of the act</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indication of the durability of the legal resource (as seen by the printer). Values such as "DUR"</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#duration">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier had to be treated during a given duration / in a given delay</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">If expressed in days, add d after the value, if expressed in weeks w, e.g. 6w, e.g. /ns4:ecTransmissionRequest/extension/ns4:delayInWeeks</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#duration">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Duration</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Duration / Extend of expression</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionPublicationGeneral"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#Duration"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#ecli">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ECLI</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">European Case Law Identifier. Identifier of the decision, including all its summaries (not necessarily unique in the CELLAR)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#edition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression edition</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">edition of this expression</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#edition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation edition</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">edition of this manifestation. mapped from 250 $a</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#eea">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource European Economic Area</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">European Economic Area. Added in the context of IMMC2CDM-OJ. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#efta">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#eli">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">European legislation identifier (ELI)</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ELI. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#embargo">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent embargo</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this agent under embargo? This instance must not be shown until the indicated datetime has been reached. In case a release date is not known,9999-12-31 should be used (= absolute embargo)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#embargo">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier embargo</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this dossier under embargo? This instance must not be shown until the indicated datetime has been reached. In case a release date is not known,9999-12-31 should be used (= absolute embargo)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#embargo">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression embargo</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this expression under embargo? This instance must not be shown until the indicated datetime has been reached. In case a release date is not known,9999-12-31 should be used (= absolute embargo)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#embargo">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Item embargo</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this item under embargo? This instance must not be shown until the indicated datetime has been reached. In case a release date is not known,9999-12-31 should be used (= absolute embargo)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Item"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#embargo">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation embargo</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this manifestation under embargo? This instance must not be shown until the indicated datetime has been reached. In case a release date is not known,9999-12-31 should be used (= absolute embargo)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#embargo">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work embargo</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this work under embargo? This instance must not be shown until the indicated datetime has been reached. In case a release date is not known,9999-12-31 should be used (= absolute embargo)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#endorsements">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endorsements in court decision</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endorsements associated with this judgement. Sector 6 Text Index Field VS</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#euSurveyIdentifier">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eu survey identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicates the euSurveyIdentifier</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EventInternal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#europeanUnionCompetenceType">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of competence conferred on the European Union</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When the Treaties confer on the Union exclusive competence in a specific area, only the Union may legislate and adopt legally binding acts;When the Treaties confer on the Union a competence shared with the Member States in a specific area, the Union and the Member States may legislate and adopt legally binding acts in that area. values: EXCLUSIVE (exclusive competence, articles 3 and 6 TUE), SHARED (shared competence with the Member States, article 4 TUE)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#eventDate">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Date of event</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The date of the event</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#Date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#eventEmbargo">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Event embargo</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this event under embargo? This instance must not be shown until the indicated datetime has been reached. In case a release date is not known,9999-12-31 should be used (= absolute embargo)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#Embargo"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#extent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Extent of manifeststion</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">extent of this manifestation. mapped from 300 $a</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#extentIllustration">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Extent illustration</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">illustration extent of this manifestation. based on 300 $b. ultiple codes that refer to table PUB_PHYS</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#fascicule">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fascicule</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#firstSeriesHistorical">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">First historical series</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">For old SPs, an indication of the series they appeared in</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OfficialJournalSpecialEdition"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#firstSeriesHistorical"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#followingCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Following case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The case law has a follow up. see 82003UK1021(01)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#formatting">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Desired formatting for the year and number sequence</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Formatting for natural number and year. values such as YN (first year then natural number) and NY (first natural number then year)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#frameworkProceduralIdentifier">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifer of the procedural framework</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The identifer of the procedural framework for the case event</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#frameworkProceduralIdentifier"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#frameworkProceduralSequentialNumberNature">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sequential number related to the nature in the identifier of the procedural framework</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The sequential number related to the nature in the identifier of the procedural framework of the case event</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#frameworkProceduralSequentialNumberTypeProcedure">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sequential number related to the type of procedure in the identifier of the procedural framework</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The sequential number related to the type of procedure in the identifier of the procedural framework of the case event</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#frequencyExpected">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expected frequency</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expected frequency of the series (e.g. M for monthly)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionPublicationGeneral"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#grounds">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Grounds for court decision</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Grounds / motivation associated with this judgement. Sector 6 Text Index Field MO</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasJurisdiction">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">work_has_jurisdiction</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTitleFromComFinal">
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Boolean property representing the information whether the titles for a COM package were taken from a COM final document or (in absence of a COM final document) from another document in the package being defined as substitute.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ComPackage"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTitleFromComFinal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">archive package has title from com final</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">indication if the title(s) of the package from the final document in the package or if the scanning provider (in absence of a final document) took the title from a substitute final document</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ArchivePackage"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#heading">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Heading of the procurement notice</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#headingPld">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Old heading</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idCelex">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Celex identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Celex identifier. CELEX number (= DN and DN2). Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idCelex">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier for case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier for the summary of case law (build on Celex identifier followed by SOM)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SummaryCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idCelex">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier for case law in JURE</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier for the summary of case law (build on Celex identifier in sector 8 followed by SUMJURE)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SummaryCaseLawJure"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idCom">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM catalogue number</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#DocumentComOtherEc"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idCom">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM identifier for proposals</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM catalogue number. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ProposalAct"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idCom">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM identifier of SEC and SWD</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">COM or SEC or SWD catalogue number. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#StaffWorkingDocument"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idDocRelated">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Natural number of related documents</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idDocSummarized">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Natural number of document summarized (basic or modifying)</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Natural number of document summarized</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idDocument">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier of document</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An alternative identifier (id) that this work may have. All identifierLike properties are subproperties of the identifier property.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idFragment">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fragment identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier of a fragment (typically an article number)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#BibliographicResourceFragment"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idLegissum">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier for the summary of EU legislation (sumleg)</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier for the summary of EU legislation (idLegissum)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idLocal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Local identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier that this legal resource in some other reference system, e.g. in the member states. Does not at present exist in EURLex</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idNumpub">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Numpub</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Numpub</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idObsoleteDocument">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Obsolete document identifier</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idObsoleteNotice">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Obsolete notice id</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Place to store the old DORISKEY or PROCATKEY. Really obsolete, only for backwards compatibility for existing notices, not to be used for new notices</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idReception">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reception identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier of the reception</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#idSector">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sector identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier of the sector (DTSEC). Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#identifier">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. the identifier of the dossier. Any type of identifier for this dossier. Dossier ID. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#PlainLiteral"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#identifier"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#identifier">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Item or content identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier of this data stream</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Item"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#identifier">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. identifier of this manifestation. mapped from 035 $a. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#identifierCase">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case identifier in the title of a case law document (languageSpecific)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#identifierCourt">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier of the Court</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Code for the court in the case identifier. Possible values C, T or F, e.g. C</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#identifierExtension">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifier of the extension in the case identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Code for the extension of the identifier in the case identifier, needed to make the identifier unique in some cases. possible values NONE, AVIS, PV, RX</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#identifierExtensionNumber">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of the identifier of the extension in the case identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of the extension of the identifier in the case identifier, needed to make the identifier unique in some cases. per default 1, to be discussed if still needed</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#identifierNumber">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number in identifier of court case</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number in the case identifier. e.g. 172</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#identifierYear">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year in identifier of court case</rdfs:label>
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">identifier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year in the case identifier. e.g. C-172/97_PV</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#impactAssessmentNeeded">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure needs impact assessment?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do the betterRegulationRequirements require an impact assessment for this internal procedure? /ns4:ecTransmissionRequest/transmission/workflow/extension/ns3:betterRegulationRequirements/ns3:impactAssessment</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#implementationPlanNeeded">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure needs implementation plan?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do the betterRegulationRequirements require an impact assessment for this internal procedure? /ns4:ecTransmissionRequest/transmission/workflow/extension/ns3:betterRegulationRequirements/ns3:implementationPlan</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#inForce">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">inForce</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicator whether a piece of legislation is currently in force or not in force. It is calculated based on the dateEntryIntoForce and dateEndOfValidity. This can be used for the sector 1,2,3,4. It should not be used for legislative proposals or drafts. For these an extra property is going to be added in a next version of the CDM. Relevant for legal analysis: true. More information can be found in EURLex legal analysis methodology.</rdfs:comment>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#inForce">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In force?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this legal resource currently in force? Could be calculated based on end of validity date. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#indicatorDecision">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decision indicator</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decision indicator in the title of a case law document (languageSpecific)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#informationLanguageExpression">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Information on language of expression</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Additional information on the language of expression. Textual information on the language of the described materials. A description of the alphabet, script, or other symbol system ...</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionPublicationGeneral"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#informationMiscellaneous">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Miscellaneous information for a general publication</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Miscellaneous information</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionPublicationGeneral"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#informationMiscellaneous">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Miscellaneous information</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Miscellaneous informations - pays destinataire de l aide alimentaire - numdoc des affaires jointes - consultation du PE, should probably be split into a number of fields. mixed content, decoded with fd_400. MI. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#informationNumber">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year and natural number of the act (precomposed)</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year and natural number of the act (combined in one string, as seen by the printer). values such as "2012/C 95/23", "2590/1980" (precomposed) --- in the future only to be used for OJNUMINF in OJ C, not for OJDOCNO</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#inherited">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression inherited</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indication if the expression is inherited from another version of the document</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#initiating">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Initiating event</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this legal event initiating?. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#internalNumberPrefix">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal number prefix</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prefix of the unique internal identifier of the resource legal. Standard and official document with the Council logo. E.g. legislative acts, working documents, information notes, agendas, minute, outcome of proceedings and other reports, Standard documents without the Council logo, e.g. EUCO, PE-CONS, ACP-CE, EUROMED, EUAL, These documents are numbered from 1 to 5000</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#internalNumberPrefix">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">archive package internal numberPrefix</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">possible (useful) values: SEC, S, G, for the subclassification of the document type</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ArchivePackage"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#internalNumberSequentialNumber">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal number sequential number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sequential number of unique internal identifier of the resource legal</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#internalNumberSuffix">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal number suffix</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Suffix of the unique internal identifier of the resource legal. The suffix serves the purpose of identifying the original document and the modifications made to it</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#internalNumberYear">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#year"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#isCorrigendumPrinter">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Printer's view if this is a corrigendum or not</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this a corrigendum? values can be C (corrigendum) or O (not a corrigendum), removed range restriction for IMMC2CDM-OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#isDeprecated">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">work dataset is deprecated</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">work dataset is deprecated, the property is useful for the MDR team to be able to flag datasets which are not used any more.</rdfs:comment>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#isSigned">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this manifestation electronically signed?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indication, if this manifestation is electronically signed. Is this manifestation signed?</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#isbn">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">isbn</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ISBN of this manifestation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#issn">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">issn</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ISSN of this manifestation. In Formex e.g. &lt;NO.ISSN&gt;18318029&lt;/NO.ISSN&gt;</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#judgementReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to a judgement</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to a judgement, typically on the European level</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#keyword">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dataset keyword</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property contains a keyword or tag describing the dataset</rdfs:comment>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#keywords">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Description</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Formal Description of a case law</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#keywords">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keywords for court decision</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Keywords associated with this judgement. Sector 6 Text Index Field IX</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#labelsFormsLinkTitle">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Labels forms title</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#labelsFormsLinkType">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Label forms type</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#labelsFormsReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference for label forms</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#landingPage">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dataset landing page</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property refers to a Web page that provide access to the dataset, its distributions and/or additional information</rdfs:comment>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#legalBasisPrinter">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Printer's legal basis of the act</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal basis of the legal resource (as seen by the printer). Values such as "EURATOM", "EC"</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#legalEffectPaper">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal effect for paper version of the Official Journal</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Does the paper version of this OJ issue have legal effect? To be included after the adoption of a regulation on electronic publication of OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OfficialJournal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#legalEffectPaper">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal effect for paper version of the special edition of the Official Journal</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Does the paper version of this OJ issue have legal effect? To be included after the adoption of a regulation on electronic publication of OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OfficialJournalSpecialEdition"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#mainActivitiesCode">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Code of main activities</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NoticePriorInformation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#mainActivitiesLabel">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Label of main activities</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NoticePriorInformation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#manifestationDistributionSource">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Distribution source</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property refers to a related resource from which the described resource is derived</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#source"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#manifestationDistributionTitle">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Distribution title</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Distribution title</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#title"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#manuscriptSef">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This element is used to mark up the reference of the manuscript sent to the printer</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manuscript reference. Added in the context of IMMC2CDM-OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#name">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Name of national Court</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Name of this national court, possibly qualified by language. e.g. &lt;name.court&gt;High Court&lt;/name.court&gt; in JURE</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#name">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Person name</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Name of this person</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<owl:sameAs rdf:resource="http://xmlns.com/foaf/0.1/name"/>
		<rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#name">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Treaty"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<created xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2018-05-25T10:45:59.663+02:00</created>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#nameMeeting">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Meeting name</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Meeting name (treated as a special type of title). Marc field 711 a and 711 c | Example: Council of Trent</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#GeneralPublication"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#string_or_title"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#nameOfficialJournal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National or regional Official Journal</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National or regional official journal in which this NIM was published</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#nationalJudgement">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National judgement</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference a un jugement prononce par un tribunal national ayant donne lieu à un renvoi. &lt;ref.legislation.national&gt;Artt. 1195 ff. des spanischen Código Civil&lt;/ref.legislation.national&gt;, lines delimted by &lt;p&gt;</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#nationalWebsiteLink">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">URI of national website</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">URI of the national website and / or the concrete work. Can be at any granularity that the sending member states consider applicable, e.g. of the website itself, of the work or of some specific format (EURLEXNEW-2124 / CADMOS-1762)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#nationalityMep">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nationality of MEP</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. refers to the nationality of the member of the European Parliament who asked the question. It is mandatory for Parliamentary questions. Currently coded by FD Table 289, could also be a link to a country. Example: 92004E1202. AF (1). AF_GROUP and AFNAT occur together. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ParliamentaryQuestion"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#naturalNumber">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Natural number of the act (decomposed)</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Natural number of the act (as seen by the printer). values such as 36, 127,...</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#natureClassification">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">documentation_nature_classification</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Documentation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#natureClassification">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">work_dataset_nature_classification</rdfs:label>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#nature_classification">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">evolutive_work_nature_classification</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EvolutiveWork"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#number">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sequential number</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#number">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Court report number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of the Court report</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CourtReport"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#number">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of the Court report</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of the Court report.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationCourtReportPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#number"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#number">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OJ number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of the OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OfficialJournal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberCatalogue">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Catalogue number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cataglogue number of this manifestation (typically, if it is a general publication). In Formex e.g. &lt;NO.CAT&gt;QDAB1001AENC&lt;/NO.CAT&gt;</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberCatalogueGlobal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Global catalogue number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">cataglogue number of this manifestation (typically, if it is a general publication). In Formex e.g. &lt;NO.CAT.GLOBAL&gt;QDAB10001ENC&lt;/NO.CAT.GLOBAL&gt;. "The NO.CAT.GLOBAL element is used to mark up the catalogue number for a whole publication which is available in various volumes which are identified separately"</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#numberCatalogueGlobal"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberCatalogueOther">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Catalogue number other</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">other cataglogue number of this manifestation (typically, if it is a general publication). based on 029 7 $a iff $2 != 'LULuPOE' # $2 is mandatory</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberContract">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contract number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contract number under which this general publication was elaborated</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#GeneralPublication"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberCorrigendum">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Corrigendum number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Sequential number of the nth corrigendum. Basis for decision on "exclude corrigenda" / DTCORR. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberCorrigendumEli">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Corrigendum number ELI</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sequential number of the nth corrigendum in the ELI, needed to disambigutate corrigendum ELIS</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#numberCorrigendumEli"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberDocumentInOfficialJournal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Document number in the Official Journal</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberEdition">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number edition</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Edition</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberNatural">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Natural number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number part. e.g. 1 for decision 2014/1</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberNaturalCelex">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Natural number (celex)</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number part of the Celex identifier (id) (DTNUM) or date ddmm. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberOfficialJournal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of national or regional Official Journal</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of national or regional official journal in which this NIM was published</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberProcedure">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of this procedure. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier number of reference</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. reference number of the dossier. Taken from Prelex, e.g. numero="471" split="1", should contain information on the split. Procedure reference number. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberSequence">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sequence number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sequence number of this document. Used to disambiguate ELIs sharing the same natural number, many cases different from numberSequenceCelex</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberSequenceCelex">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Celex sequence number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Sequence number part of the Celex identifier (id). For backlog based on IDCELEX, currently provided by legal analysis contractor. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberSession">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of session</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of session during which this preparatory act was debated or adopted, e.g. in the Committees</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PreparatoryAct"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberSession">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of a session for event</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A number of a session during which this event took place, e.g. in the Council or the Committee of the Regions</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#numberSessionPlanned">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of planned session</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of session during which this preparatory act will most likely be debated or adopted, e.g. in the Committees</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PreparatoryAct"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#nutsoriginalLinkTitle">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NUTS orignal title</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#nutsoriginalLinkType">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NUTS original type</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#nutsoriginalReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NUTS original reference</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#objectionPeriod">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Objection period</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Period (expressed in months or weeks to be confirmed) where the European Parliament and the Council have the right to object on a delegated act of the Commission</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EventInternal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#objectionPeriodExtension">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Objection period extension</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Possible extension to the period (in months) where the European Parliament and the Council have the right to object on a delegated act of the Commission</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EventInternal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#obsolete">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Summary obsolete?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An summary is considered obsolete if its basic act (= summarizes) is out of force. Is this summary obsolete? An summary is considered obsolete if its basic act (= summarizes) is out of force</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#officialFormsLinkTitle">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link title for the official forms</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#officialFormsLinkType">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link type for the official forms</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#officialFormsReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference for the official forms</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#openPublicConsultationNeeded">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure needs open public consultation?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do the betterRegulationRequirements require an open public consultation for this internal procedure? /ns4:ecTransmissionRequest/transmission/workflow/extension/ns3:betterRegulationRequirements/ns3:openPublicConsultation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#operativePart">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Operative part of court decision</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Operative part associated with this judgement. Sector 6 Text Index Field DI</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#pageFirst">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">First page</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">First page number of the OJ part related to a legal resource</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationPrint"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#pageLast">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Last page</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Last page number of the OJ part related to a legal resource</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationPrint"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#pageOfficialJournal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Page in the national or regional Official Journal</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Page in the national or regional official journal on which this NIM was published</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#pageSeq">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Page sequence</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Page sequence of the print manifestation of a act. Added in the context of IMMC2CDM-OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#pagesTotal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Total pages</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Total number of pages of the OJ part related to a legal resource</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationPrint"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#parentDocumentSef">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to the parent document of a legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parent document reference. Added in the context of IMMC2CDM-OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#parentDocumentSef"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#part1">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Part 1 of the legal basis of the procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Part 1 of the legal basis of the procedure. typical values PROT</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#part2">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Part 2 of the legal basis of the procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Part 2 of the legal basis of the procedure. typical values such as BCE</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#parties">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parties of the case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to the parties involved in this case law. Use an XML structure to capture the sequence of references</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#parties">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parties</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parties in the title of a case law document (languageSpecific)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#parties">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parties of court decision</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parties associated with this judgement. Sector 6 Text Index Field I1</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#pendingProposal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier is still pending proposal?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pending proposal. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#plannedAdoptionPeriodDateEnd">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure: End date of the planned adoption period</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">End date of the planned adoption period for this internal dossier. Information on the planned period for the public consultation. The information is always a period, so endDate must always be higher than startDate.The information is sent in all events part of the workflow Planning. Therefore the information sent in the most recent event is the most precise and has to prevail on the preceding information sent.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#plannedAdoptionPeriodDateStart">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure: Start date of the planned adoption period</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Start date of the planned adoption period for this internal dossier. Information on the planned period for the public consultation.The information is always a period, so startDate must always be lower than endDate.The information is sent in all events part of the workflow Planning. Therefore the information sent in the most recent event is the most precise and has to prevail on the preceding information sent</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#plannedConsultationPeriodDateEnd">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure: Planned consultation period date end</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#plannedConsultationPeriodDateStart">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure: Planned consultation period date start</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#plannedObjectionPeriodDateEnd">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EventInternal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<created xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2018-07-16T13:02:45.218+02:00</created>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#plannedObjectionPeriodDateStart">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EventInternal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<created xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2018-07-16T13:03:24.876+02:00</created>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#positionEesc">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Position of European Economic and Social Committee</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal reference of the opinions of the European Economic and Social Committee. limited to opinions of the European Economic and Social Committee. RI. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#preceedingCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Preceeding case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The case law has a predecessor. see 81986DE0828(01) or 81998UK0408(01)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#priorityClass">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Priority class for this preparatory act</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Priority class under which this document is treated at the EESC. Possible values A, B, B+, C, cf. Procedure of the Committee, rule 30, celex 32010Q1209(01)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ActPreparatoryEesc"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#procedureComment">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal procedure comment</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comment on the corresponding legal procedure. Obsolete, only maintained for backwards compatibility. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#procedureComment"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#procedureLanguage">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Language of procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Language of the procedure in the title of a case law document (languageSpecific)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#procedureNumber">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal procedure number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of the corresponding legal procedure. Obsolete, only maintained for backwards compatibility. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#procedureNumber"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#procedureType">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal procedure type</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Type of the corresponding legal procedure. Obsolete, only maintained for backwards compatibility. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#procedureYear">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal procedure year</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Year of the corresponding legal procedure Obsolete, only maintained for backwards compatibility. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#projection">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Projection of a map</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Projection, typically of a map (e.g. "Gauss proj.")</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionPublicationGeneral"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#published">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Question published?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Has this debate ever been published in "EP debates"? Indicates if this debate has ever been published in "EP Debates" (examples: 91998H0002, 91998H0001). In this case we have a manifestationPrint with information on the relevant publication, e.g. "Debates of the EP (French ed.):No 514 P. 0193". This type of parliamentary questions was published in the OJ from 1979 to 2000</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ParliamentaryQuestion"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#published">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Debate published?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Has this debate ever been published in "EP debates"? Indicates if this debate has ever been published in "EP Debates"</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#QuestionParliamentaryWithDebate"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#publishedInErecueil">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Published in eRecueil</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Is this case law document published in the eRecueil</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#publisher">
