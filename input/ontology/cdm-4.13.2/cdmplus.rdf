		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation has thumbnail</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A manifestation has a thumbnail (typically a jpg in the CCR). Needed for general publications</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Item"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#belongsToManifestation"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTreatyExpressionAspect">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Treaty"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#TreatyExpression"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasPrimaryLawExpressionAspect"/>
