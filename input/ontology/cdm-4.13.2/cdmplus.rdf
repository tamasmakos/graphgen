		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#addressedBy"/>
