		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">event under responsibility of an institution</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A given institution is primarily responsible for this event. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#responsibilityOf"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#responsibleForEvent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#responsibilityOfPerson">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">event under responsibility of person</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This event is under responsibility of a given person. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#responsibilityOf"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#responsibleForEvent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#responsibleForEvent">
