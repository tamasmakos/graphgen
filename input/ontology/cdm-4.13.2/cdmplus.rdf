		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to the NIM allocated by the member state</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
