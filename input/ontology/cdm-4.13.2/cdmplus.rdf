		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#partOfDossier"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsFragmentResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource contains a legal article</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#BibliographicResourceFragment"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#partOfResourceLegal"/>
