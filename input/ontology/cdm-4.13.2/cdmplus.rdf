		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#responsibilityOf"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#responsibilityOfAgent">
