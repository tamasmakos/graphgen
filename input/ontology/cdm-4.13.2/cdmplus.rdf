	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#reportedByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">European Parliament opinion has rapporteur</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This preparatory act has a rapporteur (person or committee). Relationship between person and committee is expressed via the annotation "inCommittee". Use the annotation "order" to express a possible order between committees | roles RAPP, RAPPPPIN, CMTPPIN</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OpinionEp"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#reportedBy"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#reportedByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">European Parliament report has rapporteur</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This preparatory act has a rapporteur (person or committee). role RAPP Example in rdf: &lt;CMROntology:reportEpReportedByAgent&gt;&lt;CMROntology:institution rdf:about="&amp;cellarAuthority;corporate-body/EPAGRI"&gt;&lt;skos:inScheme xmlns:skos="http://www.w3.org/2004/02/skos/core#" rdf:resource="&amp;cellarAuthority;corporate-body/"/&gt;&lt;/CMROntology:institution&gt;&lt;/CMROntology:reportEpReportedByAgent&gt;&lt;CMROntology:reportEpReportedByAgent&gt;&lt;CMROntology:person rdf:about="&amp;resource;agent/ABC"/&gt;&lt;/CMROntology:reportEpReportedByAgent&gt;... &lt;owl:Axiom&gt;&lt;!-- Link between committee and reporter --&gt;&lt;CMRAnnotation:buildInfo&gt;cdm:CDM_2.1.7 tdm:1523 xslt:3945 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:1.2.0 builddate:29/08/2014 14:23:02&lt;/CMRAnnotation:buildInfo&gt;&lt;CMRAnnotation:inCommittee&gt;{&amp;cellarAuthority;corporate-body/EPAGRI}&lt;/CMRAnnotation:inCommittee&gt;&lt;owl:annotatedSource rdf:resource="&amp;resource;oj/JOC_1997_337S_0052_01"/&gt;&lt;owl:annotatedProperty rdf:resource="&amp;cdm;reportEpReportedByAgent"/&gt;&lt;owl:annotatedTarget rdf:resource="&amp;resource;agent/ABC"/&gt;&lt;/owl:Axiom&gt;&lt;owl:Axiom&gt;&lt;!-- Order between committees --&gt;&lt;CMRAnnotation:buildInfo&gt;cdm:CDM_2.1.7 tdm:1523 xslt:3945 saxon:9.0.0.1J JVM:1.6.0_29 metaconvJar:1.2.0 builddate:29/08/2014 14:23:02&lt;/CMRAnnotation:buildInfo&gt;&lt;CMRAnnotation:order&gt;1&lt;/CMRAnnotation:order&gt;&lt;owl:annotatedSource rdf:resource="&amp;resource;oj/JOC_1997_337S_0052_01"/&gt;&lt;owl:annotatedProperty rdf:resource="&amp;cdm;reportEpReportedByAgent"/&gt;&lt;owl:annotatedTarget rdf:resource="&amp;cellarAuthority;corporate-body/EPAGRI"/&gt;&lt;/owl:Axiom&gt;</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Report"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#reportedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#reportsOnreportEp"/>
	</owl:ObjectProperty>
