		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The end date of the session during which this event took place, e.g. in the Council or the Committee of the Regions</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
