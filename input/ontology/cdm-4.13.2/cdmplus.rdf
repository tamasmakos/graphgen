	<!-- ### Object properties ### -->

	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#ReportedByPerson">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">legal event reported on by person</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This legal event is reported on by a given person. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#reportsOnEventLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#ReportedByPerson">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">event reported on by person</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This event is reported on by a given person</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#reportedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#reportsOnEvent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#accompanyingMaterialUsesLanguage">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression's accompanying material uses language</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The language of the accompanying material</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#accompanyingMaterialUses"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedByAccompanyingMaterialExpression"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#addressedByEvent">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
	</owl:ObjectProperty>
