		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Publication reference of Court decision</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Freetext information on the publication in which this judgement appeared</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#XMLLiteral"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#referencePublication"/>
