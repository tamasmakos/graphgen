		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National implementing measure implements legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to the act (directive or framework decision) that this NIM implements</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
