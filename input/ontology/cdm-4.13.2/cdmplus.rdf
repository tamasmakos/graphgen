		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Possible sourceOfLawFragments can be noted using the annotation properties sequenceNumber, prefix, /cortrans:corTransmissionRequest/cmt:transmission/cmt:workflow/cm:work/cm:extension/corext:referenceInternal</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#referenceMemberState">
