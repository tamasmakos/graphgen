		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Class of OJ</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">OJ class "R" / "A" / "E" / "M"/ "I". Distinction between the issues: the regular (R), the CE (E), the CA (A), Malte but also Gaïlique edition (M) and Urgent edition (I)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OfficialJournal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#codifiedVersion">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource codified version</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Codified version of the legal resource. Added in the context of IMMC2CDM-OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
