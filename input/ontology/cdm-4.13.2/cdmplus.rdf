	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#associatedToResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">International agreement associated to a decision and regulation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">International agreement associated to a decision or regulation. Corresponds in FORMEX to the element ASSOCIATED.TO http://formex.publications.europa.eu/formex-4/manual/manual.htm#ASSOCIATED.TO</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#InternationalAgreement"/>
