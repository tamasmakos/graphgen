		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The indent of this work</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Subdivision"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsManifestation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation contains manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. The manfestation contains another manifestation. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#partOfManifestation"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsOfficialJournal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Collection contains official journal</rdfs:label>
