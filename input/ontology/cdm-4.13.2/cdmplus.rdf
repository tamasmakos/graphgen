		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#immediatelyEnforcesResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#immediatelyEnforcesResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law suspends immediately enforces legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2 cases (2010-07-27)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#immediatelyEnforces"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#immediatelyEnforcedByCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#implementedByCountry">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National implementing measure implemented by country</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to the country that has implemented this NIM. For the data received from SecGen only information on the implementing country is available. In the future with ELI agents might be indicated more precisely (e.g. regions as legislators) and will be stored in workCreatedByAgent</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#implementedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#implementsMeasureNationalImplementing"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#implementedByMeasureNationalImplementing">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Directive implemented by national implementing measure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Directive"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#implementedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#implementsDirective"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#implementedByMeasureNationalImplementing">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource implementedBy national implementing measure</rdfs:label>
