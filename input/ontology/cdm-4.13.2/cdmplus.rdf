		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Commission's DG(s) that were involved in bringing forward this legal resource</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
