	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#reviewedByCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Judgement reviewed by case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0 cases (2012-07-31). No example currently existing. Relevant for legal analysis: true.</rdfs:comment>
