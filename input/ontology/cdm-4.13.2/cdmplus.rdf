	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#relevantForUnitAdministrative">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource is relevant for an administrative unit</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant especially for national legislation, for EU legislation implicitly EU</rdfs:comment>
