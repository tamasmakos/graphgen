		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The reference of the volume to which this package belongs (one volume can consist of one or more packages)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ArchivePackage"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
