	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#affectedByCaseCourt">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case affected by case</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This case affected by another case</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#affectedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#affectsCaseCourt"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#affectedByCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource is affected by case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. The case law in some way affects a legal resource. CD Here according to spec of advanced search the *celex* of the base act is to be indexed (= a language independent textual information). This information will be provided in the indexation notice. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#affectedBy"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#affectsCaseCourt">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case affects case</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This case affects another case</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#affects"/>
	</owl:ObjectProperty>
