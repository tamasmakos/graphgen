	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#implementsMeasureNationalImplementing">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Country implements national implementing measure</rdfs:label>
