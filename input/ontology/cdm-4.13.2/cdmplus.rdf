		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property describe the audience, where the possible values are: [PUBLIC | NOT_PUBLIC], and by default: PUBLIC</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
