		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resources does insertion a legal resource, in term of consolidation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#doesInsertionOf"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#doesRenumberingOfResourceLegal">
