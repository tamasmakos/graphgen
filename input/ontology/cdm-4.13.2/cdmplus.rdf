	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#documentsWorkDataset">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Documents</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The described resource documents dataset</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Documentation"/>
		<rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
