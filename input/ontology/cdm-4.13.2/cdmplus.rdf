		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to this procedure. e.g. 1995/0305/COD or 2012/0204/NLE or 2012/0201/COD. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
