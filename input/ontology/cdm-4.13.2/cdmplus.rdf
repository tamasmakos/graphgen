		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#summarizedBySummary"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#suspendedByResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource suspended by legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Calculated. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#suspendedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#suspendsResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#suspendsApplicationOfResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law suspends application of legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">77 cases (2010-07-27)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#suspendsApplicationOf"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#applicationSuspendedByCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#suspendsResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource suspends legal resource. SP (2) / subsequent related instrument</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#suspends"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#suspendedByResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#tableOfContentsUsesLanguage">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression's table of contents uses language</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The language of the table of contents</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
