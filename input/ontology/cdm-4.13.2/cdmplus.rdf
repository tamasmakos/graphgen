		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Subtitle of the expression. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#string_or_title"/>
	</owl:DatatypeProperty>
