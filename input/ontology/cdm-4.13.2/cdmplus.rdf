		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource addresses organization</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An act is addressed to an organization (often private). Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#addresses"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#addressedByResourceLegal"/>
