		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The work is summarized by another work (e.g. the summary of case law)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Summary"/>
