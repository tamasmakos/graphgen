		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#targetGroups">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Target groups</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicates the target groups of the internal event</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EventInternal"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#PlainLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termOfOffice">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Term of Office</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Period of time, during which, members nominated by national governments and appointed by the Council of the European Union, are mandated to issue opinions on matters of European interest to the Council, the Commission and the European Parliament. The members are acting for a renewable 5-year term of office, can also serve other concepts</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termParliamentary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term, concern documents emenating from the European Parliament. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OtherPreparatoryDocument"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termParliamentary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term during which this preparatory act was debated or adopted, e.g. in Parliament</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PreparatoryAct"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termParliamentary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term, concern documents emenating from the European Parliament. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EpInternalDecision"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termParliamentary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term, concern documents emenating from the European Parliament. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EpBudgetDocument"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termParliamentary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term, concern documents emenating from the European Parliament. LG, currently coded with FDTable 285 ("first legislature etc."). However, only codes are exposed (not decoded), so 01, 02 etc. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ParliamentaryQuestion"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termParliamentary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term, concern documents emenating from the European Parliament. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Resolution"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termParliamentary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term, concern documents emenating from the European Parliament. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ResolutionLegislative"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termParliamentary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term, concern documents emenating from the European Parliament. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Resolution"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#termParliamentary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Parliamentary term, concern documents emenating from the European Parliament. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#TextAdopted"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#tirCode">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tir code for a country</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">à revoire</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#tirCode"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#title">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier title</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. the title of the dossier. language encoded in triple as ^^ISO-Code, on Prelex typically title of initiating document, but can change e.g. in case of JAI dossiers. Datatype is rdf:PlainLiteral. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#PlainLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#title">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#PlainLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#title">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression Title</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Title of the expression. Any type of title (TI / TJ / TE...), also for case law (NOMUSUEL) and general publications. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#string_or_title"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#title">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation title</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">title of this manifestation. Optional title of this manifestation (if different from the expression title)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#string_or_title"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#title">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work title</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A title for the work itself (domain specific). Multiple usage to gather all language versions if necessary. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#string_or_title"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#titleAlternative">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alternative title</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Any alternative title(s) that this expression might have (obsolete titles, ...). Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#string_or_title"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#titleInformationAdditional">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Additional information on title</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Additional information on the type of the title (TITQUAL). Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#string_or_title"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#titlePart">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Title of part</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Name of part or section of a work. Marc fields 700 p, 710 p and 711 n | How do fields 700 p, 710 p and 711 n differ?</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#GeneralPublication"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/datatype#string_or_title"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#titleShort">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Short title</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Established short title of the expression (if any)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedAddress">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedAttention">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedContactPoint">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedCountry">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedEmail">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedFax">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedPhone">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedPostalCode">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedPrganisationNationalId">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedPrganisationOfficialName">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#transliteratedTown">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#type">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of the court report</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of the court report (Court report of the Court of Justice, parts I and II, Cour de la fonction publique). Temporary solution, should in the future be part of the court report object itself. We need the type as some judgements of the Tribual of first instance can appear both in RJII and TP</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationCourtReportPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#type">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of the special court report</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of the special court report. Temporary solution</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationSpecialCourtReportPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#type">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation type</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Type of this manifestation. Possible values are defined in the naming conventions document. Optional as some manifestations might be untyped. Untyped manifestations would, however, only be retrievale through dedicated SPARQL queries. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#type">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kept to facilitate search implementations. Some types of docs will come from Prelex too. Some of them are not in EURLex and the links point to external sites (Eg. PRES - Council press release. DTTYPE, described as Author (caseLaw) for case law. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#type">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of digital signature</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Possible values XAdEST and XAdESA</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#DigitalSignature"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#type"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#typeAct">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Act type</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of act in the national system. e.g. Acte juridique: Règlement</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#typeCourtreport">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">type court report</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">possible values: RG1, RG2, SC</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#typeDocPrinter">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Printer's typeDoc of the act</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">typeDoc of the legal resource (as seen by the printer). Values such as "DEC", the values are stored as is. They will at a future stage likely be replaced by a value for the resource type table</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#typeReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference type</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to this procedure. This will serve for the search in files. Procedure reference type. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#urgentProcedure">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Urgent procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicates if the delegated act enters into force immediately as long as no objections are expressed by the European Parliament and the Council. the possible values: (true) urgent procedure, (false) normal procedure</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EventInternal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#uri">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">External URI of a representation of this manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">External URI for this manifestation. Use manifestation type URI if this fiels is present. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#urlEtendering">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">eTendering URL</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#urlGeneral">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">General URL</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#valueType">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of value</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#version">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression version</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Free form information on the version of this expression</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#expression"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#version">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Version of summary of legislation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">What is the version of this summary? "v1", "v2", "v3"</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#version">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dataset version</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property contains a version number or other version designation of the Dataset</rdfs:comment>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#version">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work version</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Version of a work, expressed in terms specific to a class of work (e.g. final/2, draft, definitive...). Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#versionNotes">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dataset version note</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property contains a description of differences between this version and previous version of the dataset.</rdfs:comment>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#volume">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Volume of the print manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Volume of the publication. e.g. for DEBAT_PUBNO or other indication of volumes</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationPrint"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#volume">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Volume of Official Journal</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Volume of the Official Journal</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OfficialJournal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#volume">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Volume of Special Edition of the Official Journal</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Volume of the Special Edition. Consciously not a positiveInteger due to a special case, DD_1981_01_004SSOM</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OfficialJournalSpecialEdition"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#withdrawnProposal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier is already withdrawn?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Withdrawn proposal. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#workHasNumber">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">work_has_number</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#xmlSchemaDefinitionLinkTitle">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link title for the schema definition</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#xmlSchemaDefinitionLinkType">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link type for the schema definition</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#xmlSchemaDefinitionReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference for the schema definition</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#year">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year of court report</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year in which this Court report appeared</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CourtReport"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#year">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year of court report</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year in which this court report was published. Temporary solution, should in the future be part of the court report object itself</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationCourtReportPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#year"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#year">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year number of the act (decomposed)</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year of the act (as seen by the printer). values such as 2006, 1991,...</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#year">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year of special court report</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year in which this special court report was published. Temporary solution, should in the future be part of the court report object itself</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationSpecialCourtReportPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#year">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation year</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. year of this manifestation. mapped from 260 $c. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#year">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year of OJ</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year in which this OJ number appeared</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OfficialJournal"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#year">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year of the legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Year of the legal resource. DTANN. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#yearDecision">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year of the decision</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#yearProcedure">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year of procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Year of this procedure. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#yearReference">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier year of reference</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. starting year of the dossier. Year part of the reference number. Procedure reference year. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>

	<!-- ### Annotation properties ### -->

	<owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
	<owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
	<owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/date"/>
	<owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
	<owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
	<owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/rights"/>
	<owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
</rdf:RDF>