		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsPoint">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work contains point</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The point of this work</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Subdivision"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsPreamble">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work contains preamble</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Subdivision"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsRuleLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work contains rule (legal)</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Subdivision"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsSecital">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work contains recital</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Subdivision"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsSectionLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work contains section (legal)</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Subdivision"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">sourceOfLawFragment contains sourceOfLawFragment</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A sourceOfLawFragment is hierarchically above another sourceOfLawFragment</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLawFragment"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLawFragment"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#Contains"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsWork"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#partOfSourceOfLawFragment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work contains sourceOfLawFragment</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The sourceOfLawFragment of this work</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLawFragment"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsTitleLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work contains title (legal)</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Subdivision"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsUnitAdministrative">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Administrative unit contains administrative unit</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The administrative unit contains another administrative unit</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#UnitAdministrative"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#UnitAdministrative"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#partOfUnitAdministrative"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Document collection contains work</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#partOfCollectionDocument"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier contains work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This dossier contains a work. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#partOfDossier"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">event contains a work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Any event contains one or more works. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#partOfEvent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#containsWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work contains work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The work contains another work (e.g. a law contains many articles or a COM or CES document contains a number of split proposals)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#partOfWork"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#contributedToByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work is contributed to by agent</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The work is contributed to by an agent</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contributedToBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contributesWork"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#contributesWork">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contributedToByAgent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#corOpinionContainedInResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Committee of the Regions opinion on legal resource contained in legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">451 cases (2010-07-27). Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#corOpinionContainedIn"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsCorOpinionOnResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#correctedByExpression">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression corrected by another expression</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression corrected by another expression (e.g. in the case of languageSpecific corrigenda). Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#correctedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#correctsExpression"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#correctedByResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource is corrected by legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Calculated. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#correctedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#correctsResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#correctsExpression">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression corrects another expression</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression corrects another expression. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#corrects"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#correctsJudgementResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law corrects judgement</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">14 cases (2012-07-31). Example: 62007CA0161: "Corrigendum 62008TN0509"</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#correctsJudgement"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#judgementCorrectedByCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#correctsResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource corrects legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#corrects"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#correctedByResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#createdByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work is created by agent (AU)</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Our legacy data was pointing to concepts of fd_010, corporate-body and country table. We have now mapped them all to either corportate-body or country table. Relevant for legal analysis: true.\\nRelated authority or tables: Corporate bodies NAL, Countries NAL\\nEntries previously using FD_010 have been mapped to either Corporate bodies NAL, Countries NAL. AU. Related authority or tables: Corporate bodies NAL, Countries NAL, ATTO FD_010. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#createdBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#createsWork"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#createsWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent creates a work</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#creates"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#createdByAgent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#decisionReviewRequestedByCommunicationCaseNew">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CourtOfJusticeNewCaseCommunication"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#newRequestsReviewOfDecisionCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#declaredValidByCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource declared valid by case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Calculated. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaredValidBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaresValidResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#declaredVoidByCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource declared void by case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Calculated. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaredVoidBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaresVoidResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#declaredVoidByPreliminarySulingCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource declared void by preliminary ruling</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Calculated. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaredVoidByPreliminarySuling"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaresVoidByPreliminarySulingResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#declaresIncidentallyValidResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law declares incidentally valid legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">111 cases (2010-07-27). How do codes G and W differ exactly?</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaresIncidentallyValid"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#incidentallyDeclaredValidCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#declaresValidResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law declares valid legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">606 cases (2010-07-27)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaresValid"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaredValidByCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#declaresVoidByPreliminaryRulingResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law declares void by preliminary ruling legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">158 cases (2010-07-27)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaresVoidBypreliminaryRuling"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaredVoidByPreliminaryRulingCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#declaresVoidResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law declares void legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">477 cases (2010-07-27)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaresVoid"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#declaredVoidByCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#defendedByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law defended by agent</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Defending institutions, bodies or Member States (e.g. &lt;DF&gt;COMM&lt;/DF&gt;, currently coded with FD_Table 120). The role of the defendant is expressed as property in the agent class</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#defendedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#defendsInCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#defendedByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Communication on case law defended by agent</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Defending institutions, bodies or Member States (e.g. &lt;DF&gt;COMM&lt;/DF&gt;, currently coded with FD_Table 120). Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CourtOfJusticeCommunication"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#defendedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#defendsInCommunicationCjeu"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#defendsInCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent defends in case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent (typically a country or an organization) defends himself before the court. DF</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#defendsIn"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#defendedByAgent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#defendsInCommunicationCjeu">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CourtOfJusticeCommunication"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#defendedByAgent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#defersApplicationOfResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law defers application of legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1 case (2012-07-31). Example: 62008CV0001, but role not displayed in EUR-Lex</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#defersApplicationOf"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#applicationDeferredByCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#defersApplicationOfResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource defers application of legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#defersApplicationOf"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#applicationDeferredByResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliveredByAdvocateGeneral">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law delivered by advocate general</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to the Advocate General who delivered the opinion on the case (e.g. &lt;AG&gt;Mischo &lt;/AG&gt;)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliveredByCourtDependingOnAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law delivered by court depending on</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Agent is a country or supranational organisation on which the court delivering the judgment depends (e.g. EU Member States, Third Country, European Court of Human Rights, EFTA Court, International Court of Justice). Values are taken either from the table corporate body (for international courts) or country (otherwise). For JURE always from the country table.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredByCourtDependingOn"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliveredByCourtFormation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law delivered by court formation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to the Court formation who delivered the judgement (e.g. AP for Assemblée plénière). cm:work/cm:agent_work/@role="FORM_JUG"</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliveredByCourtNational">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law delivered by national court</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to the national court who delivered the judgement</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliveredByInstitution">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law delivered by court</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Court delivering this case law. Should coincide with author encoded in sector code. In case of conflict AU has priority</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliveredByJudge">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law delivered by judge</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to the Judge who delivered the judgement (e.g. &lt;JR&gt;Diez de Velasco&lt;/JR&gt;)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Advocate general delivers case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AG</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#delivers"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredByAdvocateGeneral"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredByCourtFormation"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National Court delivers case law</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#delivers"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredByCourtNational"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Institution delivers case law</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#delivers"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#deliversCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Judge delivers case law</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#delivers"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#deliveredByJudge"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#depositaryForAgreementInternational">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent is depositary for international agreement</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent (e.g. World Trade Organisation - Director-General) is depositary for an international agreement</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#InternationalAgreement"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#depositaryFor"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#storedByAgent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#depositaryForLegislationComplementary">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent is depositary for complementary legislation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent is depositary for complementary legislation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SupplementaryLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#depositaryFor"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#storedByAgent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#depositaryForTreaty">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent is depositary for treaty</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent (e.g. World Trade Organisation - Director-General) is depositary for a treaty</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Treaty"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#depositaryFor"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#storedByAgent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#derogatedByResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource derogated by legal resource</rdfs:label>
