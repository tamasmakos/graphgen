		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Codes allowing to categorize the dossier. two possible values, CWP and REFIT.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#class">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Part of court report</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CourtReport"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
