		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The case law in some way affects a legal resource. CD (inverse AJ)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#affects"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#affectedByCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#amendedByCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource amended by case law</rdfs:label>
