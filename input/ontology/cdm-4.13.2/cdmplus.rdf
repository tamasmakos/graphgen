		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Resource legal is summarized by summary of EU legislation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Resource legal is summarized by summary of EU legislation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#summarizedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#summarizesResourceLegal"/>
	</owl:ObjectProperty>
