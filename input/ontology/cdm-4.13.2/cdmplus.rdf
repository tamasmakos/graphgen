		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of the affaire. coded</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#affaireYear">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Affaire: Year</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Year of the affaire</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#age">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Age of work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Age in years IMMC2CDM-OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#agentName">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent name</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">What is the name or other designation of this agent? The name can be the name of a person, an organization..., possibly qualified by language</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#name"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#archived">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work archived</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This work is considered to be no longer applicable on the business level. The document remains visible even if archived</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#articleJournalRelated">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Related journal article</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to an article which has appeared in a juridical journal and is related to the judgement in question (e.g. &lt;NO&gt;Thompson, James E.: Common Market Law Review 1990 p.589-607&lt;/NO&gt;) NO / notes related to the decision</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#assetContent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">evolutive_work_asset_content</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EvolutiveWork"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#assetContent">
