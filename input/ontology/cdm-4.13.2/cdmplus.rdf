	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#signedBySignatureDigital">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation signed by digital signature</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This manifestation is signed by the following manifestation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#DigitalSignature"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#signedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#signsManifestation"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#signsManifestation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Digital signature signs manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This digital signature signs the following manifestation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#DigitalSignature"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#signs"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#signedBySignatureDigital"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#spatialCountry">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dataset spatial</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property refers to a geographic region that is covered by the dataset</rdfs:comment>
