		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Subdivision"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contains"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#containsSourceOfLawFragment"/>
