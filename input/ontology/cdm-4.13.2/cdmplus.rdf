		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Freetext information on the publication in which the conclusions of this judgement appeared</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
