	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#tableOfContents">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Table of contents</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Table of contents.</rdfs:comment>
