		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#relevantFor"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#renderedObsoleteByResourceLegal">
