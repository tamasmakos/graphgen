		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#summarizedBySummaryLegislationEu"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#summarizesWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Summary summarizes another work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The work is summarized by another work (e.g. the summary of case law, to be embedded)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Summary"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
