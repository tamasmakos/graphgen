		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#isTreatyFragmentManifestationReflectedIn"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTreatyFragmentWorkAspect">
