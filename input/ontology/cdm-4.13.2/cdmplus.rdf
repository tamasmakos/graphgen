		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#TreatyWork"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasPrimaryLawWorkAspect"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#isTreatyWorkReflectedIn"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeActConceptTypeAct">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource has type of act</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Related authority or tables: Resource types NAL, ATTO FD_30. Relevant for legal analysis: true. This property pointing to the deprecated NAL fd_030 is not anymore fed. Please use workHasResourceType pointing to resourceType instead. We will remove it from our instance data and ultimatively from the CDM.. The type of act in legal terms, expressed through a link to a type of act concept. FM, coded with FDTable 030Related authority or tables: Resource types NAL, ATTO FD_30. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasTypeAct"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeCommentConceptTypeComment">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of comment by a body</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comments and additional details of agreements and decisions taken by bodies created by these agreements. IC. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#InternationalAgreement"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasTypeComment"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeConceptClassCourtNational">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National Court has type classification class</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">e.g. a) Court of first instance, b) Court of appeal, c) Supreme court</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasType"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeConceptTypeDataset">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of dataset</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property indicates the type of dataset</rdfs:comment>
		<rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasType"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#isTypeOfWorkDataset"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeConceptTypeEvent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Event has type concept type event</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Event has a certain type of event. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#ConceptTypeEvent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasType"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeConceptTypeProcedureCodeInterinstitutional">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Procedure has type concept type procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Procedure has a certain type of procedure. Uses the procedure NAL. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasType"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeConcepttypeDocumentation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type of documentation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property indicates the type of documentation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Documentation"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasType"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeConsultation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Event internal has type consultation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property describes the type of consultation of the internal event</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EventInternal"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeConsultation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure has a consultation type</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This internal procedure is a certain type of consultation. Table comInternalConsultationType</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#isTypeOfProcedureInternal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeProcedureConceptTypeProcedure">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law has a type of procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The case law has a certain procedure type. PR, currently coded by FD_Table 100</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasTypeProcedure"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeProcedureConceptTypeProcedure">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Communication on case law that has a type of procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The case law has a certain procedure type. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CourtOfJusticeCommunication"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasTypeProcedure"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#hasTypeProcedureInternal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure has a type</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This internal procedure is of a certain type. Table comInternalProcedure</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#has"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#isTypeOfProcedureInternal"/>
	</owl:ObjectProperty>
