		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#amends"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#amendedByCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#amendsResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource amends legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. amends. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#amends"/>
