		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. council session number. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
