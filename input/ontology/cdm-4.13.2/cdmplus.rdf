	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#derogatesResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource derogates legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#derogates"/>
