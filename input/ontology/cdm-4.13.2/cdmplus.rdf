		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#responsibleForEvent">
