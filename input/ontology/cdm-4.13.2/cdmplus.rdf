	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#subject">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Subject for court decision</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Free text subject associated with this judgement. Sector 6 Text Index Field I2</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#subsectionPj">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sub section of the OJ</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sub section of the OJ part that this legal resource was published in. Added in the context of IMMC2CDM-OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#subtitle">
