		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference of the NIM allocated by the Commission</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalImplementingMeasure"/>
