		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Author of the legal resource (as seen by the printer). Values such as "CS", not currently normalized</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
