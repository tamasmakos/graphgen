		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Render at the source of the work transmitted</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#repertoire">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Repertoire of legislation in force</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Indicator for the extraction of titles for the production of the directory of legislation in force. Mandatory for legislation, commission proposals and agreements. REP with the following possible value: "REP": legal resource appears in the directory with a full title. "LIE": legal resource appears in the directory as a reference. "CADUC": legal resource stricken from the directory. In theory this is linked to FDTable091, but the "translations" retake the original codes This will not be translated, there are no labels used in the interface. Only the coded values are exposed</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#representationType">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">manifestation_representation_type</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#rights">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rights on manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rights on this manifestation. mapped from 540 $a</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#roadmaOneeded">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Internal procedure needs roadmap?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Do the betterRegulationRequirements require a roadmap for this internal procedure? /ns4:ecTransmissionRequest/transmission/workflow/extension/ns3:betterRegulationRequirements/ns3:roadmap</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#scale">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Scale</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Scale, typically of a map (e.g. "ca. 1:10,000")</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ExpressionPublicationGeneral"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#secondSeriesHistorical">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Second historical series</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Used for english and danish special editions containing thematic volumes (the series "II"). FYI, the themes for the volumes of the secondSeries are like follows: I. External Relations II. Agriculture and Food Aid III. European Agricultural Guidance and Guarantee Fund IV.Transport IX. Resolutions of the Council and of the Representatives of the Member States V. Euratom VI. Competition (a) and (b) VII. Institutional questions VIII. European Coal and Steel Community X. Miscellaneous</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#OfficialJournalSpecialEdition"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#section">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Section of case law publication</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#sectionPj">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Section of the OJ</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Section of the OJ part that this legal resource was published in. Values such as "L2"</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ManifestationOfficialJournalPart"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#sequence">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sequence number of the legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource sequence number. Added in the context of IMMC2CDM-OJ</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#sequence">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sequence of work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Order of the work in a group of works. IMMC2CDM-COM. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#series">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Series of the Court report</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#serviceAssociated">
