		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedByTableOfContentsExpression"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#tacklesSimilarQuestionAsResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource tackles similar question as legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Calculated. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#tacklesSimilarQuestionAs"/>
		<rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#takenPverPerson">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">legal event taken over by person</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This legal event is taken over by a given person. The XML contains two persons, the person handing over and the person taking over. This is the second of the two. Person role: Taking over. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#takenPver"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#takesPverEventLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#takesPverEventLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Person takes over legal event</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#takesPver"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#translatedByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work is translated by agent</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The work is translated by an agent (AU)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#contributedToByAgent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#translatedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#translatesWork"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#translatesWork">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#translatedByAgent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#treatsAppealCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case treats the appeal against a case law document</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An appeal against an existing case law is discussed in this case</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#treatsAppeal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usedByAccompanyingMaterialExpression">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Language used by accompanying material</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A given language is used for the accompanying material of an expression (typically of a general publication)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedByAccompanyingMaterial"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usedByExpression">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Language used by expression</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A given language is used by an expression</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedBy"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usedByTableOfContentsExpression">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Language used by table of contents expression</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A given language is used for the table of contents of an expression (typically of a general publication)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedByTableOfContents"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usedByoriginalTranslationExpression">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Language used by original translation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A given language is used for the original translation of an expression (typically of a general publication)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedByoriginalTranslation"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usedForDraftingSummaryLegislationEu">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Language used for drafting summary of EU legislation</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedForDrafting"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#draftedInLanguage"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usedForDraftingWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Language used for drafting a work</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedForDrafting"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#draftedInLanguage"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usedoriginallyByProcurementPublic">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usesOriginallyLanguage"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usedoriginallyByResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Language used originally by legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A given language is used for the authentic language version of a legal resource. LF / authentic language</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedoriginallyBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usesOriginallyLanguage"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usesConceptModeDecision">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Event internal uses concept mode decision</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property describes the concept mode decision of the internal event</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#EventInternal"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#uses"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usesConceptModeDecision">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The event operates under a given decision mode</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Change from the modeDecision data property, encoded via FD_606. Decision mode. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#uses"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usesConceptTypeDecision">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The event uses a given decision type</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Change from the typeDecision data property. Decision. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#uses"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usesLanguage">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression uses language</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. The expression uses a given language (can be repeated to cover expressions in several languages). Implicit in the TITXX, Marc field 41 a. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#uses"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedByExpression"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usesOriginallyLanguage">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Public procurement uses originally language</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Authentic language version of a public procurement notice</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#PublicProcurement"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usesOriginally"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usesOriginallyLanguage">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource uses originally language</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This property used to point to both fd_060 and language tables. Our instance data is now fully pointing to the language table. Authentic language version of an act or a European Court case. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usesOriginally"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usedoriginallyByResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#usesProcedureLanguage">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law uses language of procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The case uses a given language of procedure</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#usesProcedure"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#validatedByInstitution">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Summary validated by a corporate body</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Corporate body which validated this summary</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#validatedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#validatesSummaryLegislationEu"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#validatesSummaryLegislationEu">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Institution validates a summary of EU legislation</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuxillaryResource"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#validates"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#validatedByInstitution"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#validationRequestedByCaseLaw">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Validation of legal resource requested by case law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4 cases (2012-07-31). Example: 62008CN0373: "validation request 32004R0398". Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#validationRequestedBy"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#validityExtendedByResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource has validity extended by legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Calculated. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#validityExtendedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#extendsValidityOfResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#wasHistoricallyAboutConceptTypeDossier">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier was about historical dossier type concept</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This dossier was at the time of the event of a certain type, expressed through a dossier type concept. Expressed through a link to the conceptTypeDossier, currently FD table 612, previously known as typeDossierHistorical. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#wasHistoricallyAbout"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#wasHistoricallyAboutConceptTypeProcedureCodeInterinstitutional">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Procedure had type concept type procedure</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">At the time of the event the procedure had a certain type of procedure. Change from the typeProcedureHistorical data property. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#wasHistoricallyAbout"/>
	</owl:ObjectProperty>

	<!-- ### Datatype properties ### -->

	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdm/cmr#creationDate">
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdm/cmr#lang">
		<rdfs:label xml:lang="en">used language</rdfs:label>
		<rdfs:comment xml:lang="en">May be applied on several objects.When applied on the cellar URI of an expression, it indicated the used languag of that expression.</rdfs:comment>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdm/cmr#lastModificationDate">
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdm/cmr#manifestationMimeType">
		<rdfs:label xml:lang="en">manifestation MIMEType</rdfs:label>
		<rdfs:comment xml:lang="en">The MIME type associated with a manifestation, and thus with all principal content streams of that manifestation. "principal" here means the top level content stream MIME type. (e.g. a principal or content stream may be in xhtml, while this xhtml may carry images in tiff, Ong or other formats) Such top level content streams are in the PO metsMessage accessed with: - mets/fileSec/fileGrp/file</rdfs:comment>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
		<rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#abstract">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abstract of expression</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Abstract of expression</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#accessUrl">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Distribution access URL</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property contains an URL that gives access to the distribution of a dataset. The resource at the access URL may contain information about how to get the Dataset</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#actReferenceEuropean">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to a European act in free text</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to a European act in free text, e.g. "Richtlinie 88/361/EWG des Rates vom 24. Juni 1988". VOLET_JUR_NAT/SUIVI is mapped on the element abstract of the corresponding expression</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#actReferenceInternational">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to an international convention</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to an international convention applied in the national judgment, e.g. "INT. - European Convention for the Protection of Human Rights and Fundamental Freedoms of 4 November 1950, Article 7". Use an XML structure to capture the sequence of references</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#actReferenceNational">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to provisions of national law</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference to provisions of national law applied in the national judgment, e.g. "Codice di procedura civile, art. 360, 737 e 738", "Legge 24/07/1954 no. 722". Use an XML structure to capture the sequence of references</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#XMLLiteral"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#adoptedProposal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier is already adopted?</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adopted proposal. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#affaireJurisdiction">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Affaire: Jurisdiction</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jurisdiction of the affaire. coded</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#affaireNumber">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Affaire: Number</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Number of the affaire</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#affaireType">
