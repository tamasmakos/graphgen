		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law requests annulment of legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">757 cases (2012-07-31). Example: 62011CN0429: "Annulment request 62008TA0208"</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
