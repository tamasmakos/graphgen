		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comment on dossier</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comment on the dossier as a whole. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://www.w3.org/1999/02/22RdfSyntaxNs#PlainLiteral"/>
