	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#addressedByResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent addressed by legal resource</rdfs:label>
