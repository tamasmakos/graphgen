	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#confidentiality">
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property define the confidentiality level, where the possible values are [UNRESTRICTED | RESTRICTED]. Default: UNRESTRICTED</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
