		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Complementary lesiglation is stored by an agent acting as depositary. DP (1) / depositary. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SupplementaryLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
