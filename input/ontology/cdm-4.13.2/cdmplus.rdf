		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reference of the volume in which this COM package is contained</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#ComPackage"/>
