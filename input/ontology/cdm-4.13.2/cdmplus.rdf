		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treaty stored by agent</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. Treaty is stored by an agent acting as depositary. DP (3) / depositary. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Treaty"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
