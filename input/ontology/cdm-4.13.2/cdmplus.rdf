	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#applicationExtendedByResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource has application extended by legal resource</rdfs:label>
