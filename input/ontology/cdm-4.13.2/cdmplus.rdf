	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#reproductionOfManifestation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation reproduction of manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">manifestation used as the basis for a reproduction. Reciprocal relationship: reproduced as (after RDA J.4.2.)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#reproductionOf"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#requestedByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law requested by agent</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Institution, organe ou pays requerant (e.g. &lt;AP&gt;FONC &lt;/AP&gt;). The role of the applicant is expressed as property in the agent class, currently coded by FD_110</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#requestedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#requestsCaseLaw"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#requestedByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Communication on case law requested by agent</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Institution, organe ou pays requerant (e.g. &lt;AP&gt;FONC &lt;/AP&gt;). Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CourtOfJusticeCommunication"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#requestedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#requestsCommunicationCjeu"/>
	</owl:ObjectProperty>
