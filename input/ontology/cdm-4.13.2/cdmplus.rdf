		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legacy date of creation. Relevant for legal analysis: true. Procat and Pegase legacy creation dates. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#dateCreationLegacy"/>
	</owl:DatatypeProperty>
	<owl:DatatypeProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#date">
