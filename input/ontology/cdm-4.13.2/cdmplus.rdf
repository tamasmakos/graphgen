		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#associatedWith"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#associatedWithEventLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Institution associated with legal event</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#associatedWith"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#associatedWithInstitution">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">event associated with institution</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This event is associated with a given institution. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#associatedWith"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#associatedWithEvent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#associatedWithPerson">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">event associated with person</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This event is associated with a given person. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#associatedWith"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#associatedWithEvent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#associatedWithPerson">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">legal event associated with person</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This legal event is associated with a given person. Body role:Associated. Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#associatedWith"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#associatedWithEventLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#associatesAgreementInternational">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decision or regulation associates an international agreement</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Decision or regulation associates an international agreement</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#InternationalAgreement"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#associates"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#authoredByAgent">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work is authored by agent</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The work is authored by an agent</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#authoredBy"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#createdByAgent"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#authorsWork"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#authorsOpinionEventLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Institution authors opinion on legal event</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#authorsOpinion"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#authorsReportEventLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Institution authors report on legal event</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#AuthorsReport"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#authorsWork">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#authoredByAgent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basedOnConceptTreaty">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource based on treaty concept</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to the treaty/treaties that form the legal basis under which the document has been or is being adopted. TT (treaty). Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basedOn"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisForResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basedOnResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Case law based on a legal instrument</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Possible values: Brussels Convention → 41968A0927(01), Lugano Convention → 22009A0610(01), Brussels I regulation → 32001R0044, Brussels II regulation → 32000R1347, New Brussels II regulation → 32003R2201</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basedOn"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisForCaseLawNational"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basedOnResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier based on legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dossier is based on a legal resource (typically a treaty article, but could also be secondary legislation)</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basedOn"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisForDossier"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basedOnResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">event based on legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. This event is based on a legal resource (typically a treaty article, but could also be secondary legislation). Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basedOn"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisForEvent"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basedOnResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource is based on legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to the legal resource (e.g. framework directive, international agreement...) that form the legal basis under which the document has been adopted. Additional information (LBDNPLUS, LBDNCOMMENT) to be stored as annotation properties. LB (legal basis), Here according to spec of advanced search the *celex* of the base act is to be indexed (= a language independent textual information). This information will be provided in the indexation notice. Relevant for legal analysis: true . Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basedOn"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisForResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basedOnSuggestedResourceLegal">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<created xmlns="http://purl.org/dc/terms/" rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2018-07-20T08:53:56.623+02:00</created>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basisForCaseLawNational">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#NationalCaseLaw"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basedOnResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basisForDossier">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basisForEvent">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basisForEventLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource is basis for a legal event</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. The legal resource serves as basis for a legal event (typically, but not necessarily a treaty article). Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisFor"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basisForProcedureCodeInterinstitutional">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource is basis for a procedure with interinstitutional code</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. The legal resource serves as basis for a procedure (typically, but not necessarily a treaty article). Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisFor"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basisForProcedureWithoutCodeInterinstitutional">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource is basis for a procedure without interinstitutional code</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relevant for legal analysis: true. The legal resource serves as basis for a procedure (typically, but not necessarily a treaty article). Relevant for legal analysis: true</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Dossier"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisFor"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basisForResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treaty is basis for a legal resource</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisFor"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#ResourceLegalBasedOnConceptTreaty"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basisForResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resource is basis for legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to the legal resource (e.g. framework directive, international agreement...) that is based on the legal basis under which the document has been adopted. never directly specified, inverse property of LB. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisFor"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basedOnResourceLegal"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#basisForResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Treaty is basis for legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Treaty"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#basisFor"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#belongsToManifestation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Binding of a manifestation</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#belongsTo"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasBinding"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#belongsToManifestation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Item belongs to manifestation</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An item belongs to a given manifestation</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Item"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#belongsTo"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasItem"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#belongsToManifestation">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pricing info of a manifestation</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#belongsTo"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#belongsToManifestation">
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Item"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Manifestation"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#belongsToPublicationGeneral">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Target audience belongs to general publication</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Concept"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#GeneralPublication"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#belongsTo"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasTargetAudience"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#belongsToTypeCourtReport">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manifestation published in a type of court report</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#CourtReportManifestation"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#TypeCourtReport"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#belongsTo"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#belongsToWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression belongs to a work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Expression of a given work. Implicit in the current notice structure. Relevant for legal analysis: true.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Expression"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#belongsTo"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#hasExpression"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#cataloguedByWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work is catalogued by work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The work is catalogued by another work, e.g. by publishing a list of titles</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#cataloguedBy"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#cataloguesWork"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#cataloguesWork">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Work catalogues a work</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The work catalogues by another work, e.g. by listing its titles</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Work"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#catalogues"/>
		<owl:inverseOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#cataloguedByWork"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#citedByWork">
