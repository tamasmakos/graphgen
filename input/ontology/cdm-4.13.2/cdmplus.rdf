	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#doesDeletionOfResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resources does deletion of legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resources does deletion a legal resource, in term of consolidation.</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#doesDeletionOf"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#doesImpactOfResourceLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resources does impact of legal resource</rdfs:label>
		<rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Legal resources does impact a legal resource, in term of consolidation, the impact can be: deletion, insertion, renumbering, repeal and replacement</rdfs:comment>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#SourceOfLaw"/>
		<rdfs:subPropertyOf rdf:resource="http://publications.europa.eu/ontology/cdmplus#doesImpactOf"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#doesInsertionOfResourceLegal">
