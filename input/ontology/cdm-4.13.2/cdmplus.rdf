		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
		<rdfs:range rdf:resource="http://publications.europa.eu/ontology/cdmplus#Event"/>
	</owl:ObjectProperty>
	<owl:ObjectProperty rdf:about="http://publications.europa.eu/ontology/cdmplus#responsibleForEventLegal">
		<rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Institution responsible for legal event</rdfs:label>
		<rdfs:domain rdf:resource="http://publications.europa.eu/ontology/cdmplus#Agent"/>
